{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default HOP desktop capability",
  "windows": ["main", "main*"],
  "permissions": [
    "core:default",
    "dialog:default",
    "fs:default",
    "fs:allow-open",
    "fs:allow-stat",
    "fs:allow-read",
    "fs:allow-write",
    "fs:allow-remove",
    "log:default",
    "store:default"
  ]
}
